# === Auth Toolkit - Variables de entorno ===
# Copiar a .env:  cp .env.example .env

# PostgreSQL
POSTGRES_USER=auth_toolkit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=auth_toolkit

# Redis
REDIS_PASSWORD=change-me-redis-password

# Auth Service
AUTH_LOG_LEVEL=info
AUTH_REDIS_DB=0
AUTH_DEFAULT_ACCESS_TTL=3600
AUTH_DEFAULT_REFRESH_TTL=2592000

# Token Manager
TM_SECRET_KEY=change-me-random-64-chars
TM_ADMIN_DEFAULT_PASSWORD=change-me-admin-password
TM_LOG_LEVEL=info
